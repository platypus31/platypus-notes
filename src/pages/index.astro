---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const typeLabel: Record<string, string> = {
  interest: '總覽',
  concept: '概念',
  insight: '洞察',
  event: '事件',
  reflection: '反思',
  reference: '分析',
  note: '筆記',
};

function fmtDate(d: Date) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}
---
<Layout title="platypus.notes · 價值投資筆記">
  <section class="hero">
    <h1>價值投資筆記</h1>
    <p class="lede">
      一個專注在長期、基本面、護城河的學習紀錄。<br/>
      整理我自己讀過、想過、寫過的東西 — 護城河、安全邊際、估值、複利、心理偏誤。
    </p>
  </section>

  <section class="notes">
    <h2 class="list-title">全部筆記 <span class="count">({notes.length})</span></h2>
    <ul class="note-list">
      {notes.map(n => (
        <li class="note-item">
          <a href={`/notes/${n.id.replace(/\.md$/, '')}/`}>
            <div class="note-meta">
              <span class="badge badge-{n.data.type}">{typeLabel[n.data.type] ?? n.data.type}</span>
              <time>{fmtDate(n.data.date)}</time>
            </div>
            <h3 class="note-title">{n.data.title}</h3>
            {n.data.summary && <p class="note-summary">{n.data.summary}</p>}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .hero {
      padding: 1rem 0 2.5rem;
      margin-bottom: 1rem;
    }
    .hero h1 {
      font-size: 2.4rem;
      margin: 0 0 1rem;
      letter-spacing: -0.03em;
    }
    .lede {
      color: var(--fg-muted);
      font-size: 1.05rem;
      line-height: 1.7;
      margin: 0;
    }
    .list-title {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--fg-muted);
      border-top: none !important;
      padding-top: 0 !important;
      margin-top: 0;
    }
    .count { color: var(--fg-muted); font-weight: 400; }
    .note-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .note-item {
      margin-bottom: 0.3rem;
    }
    .note-item a {
      display: block;
      padding: 1.1rem 1rem;
      border: 1px solid transparent;
      border-radius: 6px;
      color: inherit;
      text-decoration: none;
      transition: border-color 0.15s, background 0.15s;
    }
    .note-item a:hover {
      border-color: var(--border);
      background: var(--bg-elev);
    }
    .note-meta {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-bottom: 0.4rem;
      font-size: 0.82rem;
      color: var(--fg-muted);
    }
    .badge {
      display: inline-block;
      padding: 0.1rem 0.55rem;
      border-radius: 3px;
      font-size: 0.75rem;
      background: var(--bg-elev);
      border: 1px solid var(--border);
      color: var(--fg-muted);
    }
    .badge-concept { border-color: #4a7b9e; color: #8ec4e2; }
    .badge-insight { border-color: #c48a4b; color: var(--accent); }
    .badge-reflection { border-color: #7a6ec4; color: #ab9ae2; }
    .badge-event { border-color: #c46e6e; color: #e29a9a; }
    .note-title {
      font-size: 1.15rem;
      margin: 0 0 0.25rem;
      color: var(--fg);
      line-height: 1.4;
    }
    .note-summary {
      margin: 0.2rem 0 0;
      color: var(--fg-muted);
      font-size: 0.92rem;
      line-height: 1.5;
    }
  </style>
</Layout>
